{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "INIT_SCENARIO packet",
  "type": "object",
  "required": ["type", "data", "signature"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "INIT_SCENARIO" },
    "signature": { "type": "string", "minLength": 64, "maxLength": 64 },
    "data": {
      "type": "object",
      "required": ["scenario_id", "vessels"],
      "properties": {
        "scenario_id": { "type": "string" },
        "wind": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        },
        "vessels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "side", "pos"],
            "properties": {
              "id":      { "type": "integer" },
              "type":    { "type": "string" },
              "side":    { "type": "string" },
              "pos":     { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
              "heading": { "type": "number", "minimum": 0, "maximum": 359 },
              "crew":    { "type": "object" },
              "equipment": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
