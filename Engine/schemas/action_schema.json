{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PLAYER_ACTION packet",
  "type": "object",
  "required": ["type", "data", "signature"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "PLAYER_ACTION" },
    "signature": { "type": "string", "minLength": 64, "maxLength": 64 },
    "data": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id":       { "type": "integer" },
              "mp_used":  { "type": "integer", "minimum": 0, "maximum": 12 },
              "vector":   { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
              "action":   { "type": "string", "enum": ["MOVE", "RAM", "OAR_RAKE", "HOLD"] }
            }
          }
        }
      }
    }
  }
}
